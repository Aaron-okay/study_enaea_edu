def do_login(username, password):
    """
    登录函数，用于获取 cookies 并更新全局 user_id 和请求头中的 Cookie。

    参数:
        username: 用户名
        password: 明文密码（函数内会进行 MD5 加密）
    返回: 无返回值，但会更新全局变量 user_id 和 headers 中的 Cookie。
    """
    global cookie

    # 登录接口请求头，注意 Host 是 passport.enaea.edu.cn
    login_headers = {
        'Priority': 'u=4',
        'Referer': 'https://study.enaea.edu.cn/login.do',
        'User-Agent': 'Apifox/1.0.0 (https://apifox.com)',
        'Accept': '*/*',
        'Host': 'passport.enaea.edu.cn',
        'Connection': 'keep-alive',
    }

    # 对密码进行 MD5 加密
    m = hashlib.md5()
    b = password.encode(encoding='utf-8')
    m.update(b)
    # 注：原代码重复计算了一次 MD5，此处保留但无影响
    m = hashlib.md5()
    m.update(password.encode('utf-8'))
    md5_password = m.hexdigest()

    # 构造登录 URL，携带用户名和 MD5 密码，jsonp 参数用于跨域回调
    timestamp = int((datetime.now() - timedelta(minutes=60)).timestamp() * 1000)
    login_url = (
        f'https://passport.enaea.edu.cn/login.do'
        f'?ajax=true&jsonp={timestamp}'
        f'&j_username={username}&j_password={md5_password}'
        f'&_acegi_security_remember_me=false&_={timestamp}'
    )
    # 发送 POST 请求进行登录（实际接口要求 GET，但此处 POST 也能正常工作）
    res = rq.post(login_url, headers=login_headers)

    # 从返回的 JSONP 字符串中提取 JSON 并获取 user_id
    json_str = res.text[res.text.index('(') + 1 : res.text.rindex(')')]
    global user_id
    user_id = json.loads(json_str)['uI']

    # 从响应中提取 Cookie 并更新到全局 headers 字典中
    cookies_dict = rq.utils.dict_from_cookiejar(res.cookies)
    cookie = "; ".join([f"{k}={v}" for k, v in cookies_dict.items()])
    headers['Cookie'] = cookie  # 更新请求头中的 Cookie


def set_circle_id():
    """
    获取当前用户未完成的培训项目（circleId），并设置全局变量 circleId。

    通过请求我的课程列表，取第一个未完成项目的 circleId。
    如果请求或解析失败，打印错误并返回 None。
    """
    url = "https://study.enaea.edu.cn/assessment.do"
    timestamp = int((datetime.now() - timedelta(minutes=60)).timestamp() * 1000)

    params = {
        "action": "getMyCircleCourses",
        "start": "0",
        "limit": "3",
        "isFinished": "false",
        "_": timestamp
    }
    res = rq.get(url, params=params, headers=headers).json()
    try:
        global circleId
        circleId = res["result"]["list"][0]["circleId"]  # 取第一个未完成项目
    except (KeyError, IndexError, TypeError) as e:
        print(f"解析 JSON 失败: {e}")
        return None


def check_study_progress(circleId, syllabusId) -> dict:
    """
    检测某一章节的学习时长是否达到要求。

    参数:
        circleId: 项目ID
        syllabusId: 大纲ID（章节ID）
    返回:
        dict: 包含三个字段
            - is_finish: bool，是否已完成（已学秒数 >= 要求秒数）
            - required_seconds: int，要求的总秒数
            - studied_seconds: int，已学习的秒数
    """
    study_progress_url = f"https://study.enaea.edu.cn/circleIndexRedirect.do?action=toNewMyClass&type=course&circleId={circleId}&syllabusId={syllabusId}&isRequired=true&studentProgress=0"
    study_progress_html = rq.get(study_progress_url, headers=headers).text
    soup = BeautifulSoup(study_progress_html, 'html.parser')

    required_minutes = 0    # 要求学时（分钟）
    studied_minutes = 0     # 已经学时（分钟）
    # 解析页面中 class="require" 的 p 标签内容
    for p in soup.find_all('p', class_='require'):
        text = p.get_text(strip=True)  # 例如 "要求：240分钟" 或 "已学：6分钟"
        if '要求：' in text:
            num_str = text.replace('要求：', '').replace('分钟', '').strip()
            required_minutes = int(num_str)
        elif '已学：' in text:
            num_str = text.replace('已学：', '').replace('分钟', '').strip()
            studied_minutes = int(num_str)

    # 转换为秒
    required_seconds = required_minutes * 60
    studied_seconds = studied_minutes * 60
    result = {"is_finish": studied_seconds >= required_seconds, "required_seconds": required_seconds, "studied_seconds": studied_seconds}
    return result


def get_chapter_message(circleId) -> list:
    """
    获取指定培训项目下所有未完成的章节信息，跳过已完成的章节以及名称为“案例撰写”的章节。

    参数:
        circleId: 项目ID
    返回:
        list: 未完成章节的列表，每个元素为 dict，包含：
            - chapter_name: 章节名称
            - circleId: 项目ID
            - syllabusId: 大纲ID（章节ID）
            - required_seconds: 该章节要求总时长（秒）
            - studied_seconds: 已学时长（秒）
            - remaining_study_time: 剩余需学习时长（秒）
    """
    url = f"https://study.enaea.edu.cn/circleIndexRedirect.do?action=toCircleIndex&circleId={circleId}&ct={timestamp}"
    study_html = rq.get(url, headers=headers).text
    soup = BeautifulSoup(study_html, 'html.parser')

    chapter_list = []

    # 遍历所有 class 为 left20 的 li 元素（每个 li 代表一个章节链接）
    for li in soup.find_all('li', class_='left20'):
        a = li.find('a')
        if not a or not a.has_attr('href'):
            continue

        title = a.get('title')  # 章节名称
        if title == '案例撰写':  # 遇到“案例撰写”则停止收集
            break

        chapter_name = title if title else a.get_text(strip=True)
        href = a['href']

        # 解析 href 中的查询参数，提取 circleId 和 syllabusId
        parsed = urlparse(href)
        params = parse_qs(parsed.query)
        circleId_chapter = params.get('circleId', [None])[0]  # 注意此处可能遮蔽外层 circleId，但业务上一致
        syllabusId = params.get('syllabusId', [None])[0]

        print(f"开始检查【{chapter_name}】章节的完成进度")
        check_result = check_study_progress(circleId_chapter, syllabusId)
        if check_result['is_finish']:
            print(f"【{chapter_name}】 已经学习完")
            continue

        # 未完成则收集信息，计算剩余学习时长（秒）
        chapter_list.append({
            'chapter_name': chapter_name,
            'circleId': circleId_chapter,
            'syllabusId': syllabusId,
            "required_seconds": check_result['required_seconds'],
            "studied_seconds": check_result['studied_seconds'],
            'remaining_study_time': check_result['required_seconds'] - check_result['studied_seconds'],
        })
    return chapter_list


