def watch_videos(result_chapters: List[Dict], interval: int = 60) -> None:
    """
    模拟观看视频：遍历已规划的学习列表，每隔 interval 秒向服务器发送学习日志（心跳），
    直到所有视频的剩余时长被观看完毕。

    参数:
        result_chapters: get_study_list_v2 返回的章节列表，包含 course_list 和 content_list
        interval: 心跳间隔秒数，默认 60 秒
    """
    total_videos = 0
    total_time_needed = 0

    # 统计总视频数和总剩余观看时长
    for chapter in result_chapters:
        for course in chapter.get('course_list', []):
            for video in course.get('content_list', []):
                total_videos += 1
                length = video['length']
                progress = int(video['studyProgress'])
                remaining = int(length * (1 - progress / 100))
                total_time_needed += remaining

    if total_videos == 0:
        print("没有需要观看的视频。")
        return

    print(f"共 {total_videos} 个视频待观看，预计总剩余观看时间 {total_time_needed} 秒，开始模拟...")
    current_global_remaining = total_time_needed   # 全局剩余时间（仅用于显示，实际以视频为单位控制）
    video_index = 0

    for chapter in result_chapters:
        chapter_name = chapter['chapter_name']
        circle_id = chapter['circleId']
        for course in chapter.get('course_list', []):
            course_title = course['course_title']
            for video in course.get('content_list', []):
                video_index += 1
                course_id = course['course_id']
                course_content_id = video['video_id']  # 视频内容ID
                file_name = video['fileName']
                length = video['length']
                progress = int(video['studyProgress'])
                remaining = int(length * (1 - progress / 100))  # 本视频还需观看秒数

                print(f"\n[{video_index}/{total_videos}] 开始观看《{course_title} - {file_name}》")
                print(f"  视频总长 {length} 秒，已看进度 {progress}%，剩余 {remaining} 秒")

                watched = length * (progress / 100)  # 本视频已累计观看秒数（浮点）
                while watched < length:
                    # 生成当前时间戳用于请求
                    ts = int(time.time() * 1000)
                    data = f'id={str(course_content_id)}&circleId={str(circle_id)}&finish=false&ct={str(ts)}'

                    # 观看视频前需要更新 Cookie（获取视频相关的会话标识）
                    get_watch_video_cookie(course_id, course_content_id, circle_id, ts)
                    # 等待 interval 秒，模拟观看间隔
                    time.sleep(interval)

                    # 发送学习日志心跳
                    try:
                        resp = rq.post('https://study.enaea.edu.cn/studyLog.do',
                                       headers=headers, data=data)

                        if resp.status_code == 200 and resp.json()['success'] != False:
                            # 心跳成功，更新已观看秒数
                            next_watched = watched + interval
                            watched = next_watched
                            current_global_remaining -= interval
                            print(f"  心跳发送成功 (已观看 {next_watched}/{length} 秒)")
                        else:
                            print(f"  心跳返回异常状态码: {resp.json()['message']}")
                    except Exception as e:
                        print(f"  网络错误: {e}，稍后重试...")
                        time.sleep(5)
                        continue

                    # 如果不是最后一次，则等待 interval 秒；最后一次等待实际剩余时间
                    if watched < remaining:
                        time.sleep(interval)

                print(f"  《{file_name}》观看完毕。")

    print("\n所有视频观看模拟完成！")


def get_watch_video_cookie(course_id, course_content_id, circleId, ts):
    """
    获取观看视频所需的特定 Cookie，并更新到全局 headers 中。

    通过请求 statisticForCCVideo 接口，从响应头的 Set-Cookie 中提取
    动态生成的 SCFUCKP_xxx_course、SERVERID、SERVERCORSID 等值，并合并到现有 cookie 中。

    参数:
        course_id: 课程ID
        course_content_id: 视频内容ID
        circleId: 项目ID
        ts: 当前时间戳（毫秒）
    """
    url = f"https://study.enaea.edu.cn/course.do?action=statisticForCCVideo&courseId={course_id}&coursecontentId={course_content_id}&circleId={circleId}&_={ts}"
    try:
        set_cookie_str = rq.get(url, headers=headers).headers['Set-Cookie']
        # 解析 Set-Cookie 字符串为字典
        temp = {}
        for item in set_cookie_str.split(', '):
            name, value = item.split('=', 1)
            value = value.split(';')[0]  # 去掉后面的 Path、SameSite 等属性
            temp[name] = value
        # 提取需要的三个值
        scfuckp_course = temp[f'SCFUCKP_{user_id}_{course_id}_course']
        server_id = temp['SERVERID']
        server_cors_id = temp['SERVERCORSID']

        # 将 cookie 字符串转换为有序字典以便修改
        cookie_dict = OrderedDict()
        for item in cookie.split('; '):
            if '=' in item:
                key, val = item.split('=', 1)
                cookie_dict[key] = val
            else:
                cookie_dict[item] = None

        # 更新动态键值
        scfuckp_key = f'SCFUCKP_{user_id}_{course_id}_course'
        cookie_dict[scfuckp_key] = scfuckp_course
        cookie_dict['SERVERID'] = server_id
        cookie_dict['SERVERCORSID'] = server_cors_id

        # 重新拼接为 cookie 字符串并更新到请求头
        new_cookie = '; '.join(f'{k}={v}' if v is not None else k for k, v in cookie_dict.items())
        headers.update({'Cookie': new_cookie})

    except rq.exceptions.RequestException as e:
        print(f"请求出错: {e}")


def select_videos_for_course(video_list: List[Dict], target_seconds: int) -> List[Dict]:
    """
    从课程的视频列表中选择若干视频，使其总剩余时长最接近 target_seconds（不超过目标）。

    该函数通过 0-1 背包动态规划求解，优先选择总剩余时长不超过 target_seconds 的最大组合。
    若所有视频剩余时长都大于目标，则选择剩余时长最小的一个视频。

    参数:
        video_list: 视频详情列表，每个字典包含：
            - id: 视频ID
            - filename: 文件名（第几集）
            - studyProgress: 学习进度百分比（字符串 "0"~"100"）
            - length_sec: 视频总时长（秒，整数）
        target_seconds: 该课程还需观看的剩余总时长（秒）

    返回:
        选中的视频列表（按剩余时长升序排列），每个视频字典额外包含 remaining_sec 字段。
        如果所有视频均已学完，返回空列表。
    """
    # 过滤已学完的视频并计算剩余时长
    unfinished = []
    for v in video_list:
        if int(v["studyProgress"]) == 100:
            print(f"    视频《{v['filename']}》已学完，跳过")
            continue
        remaining = v["length_sec"] - int(v["length_sec"] * int(v["studyProgress"]) / 100)
        unfinished.append({
            **v,
            "remaining_sec": remaining
        })

    if not unfinished:
        print("    该课程下所有视频均已完成")
        return []

    n = len(unfinished)
    rem_list = [v["remaining_sec"] for v in unfinished]

    # 动态规划：0-1背包，求不超过 target_seconds 的最大剩余时长之和
    dp = [0] * (target_seconds + 1)
    choose = [[False] * (target_seconds + 1) for _ in range(n)]

    for i in range(n):
        rem = rem_list[i]
        for j in range(target_seconds, rem - 1, -1):
            if dp[j - rem] + rem > dp[j]:
                dp[j] = dp[j - rem] + rem
                choose[i][j] = True
            else:
                choose[i][j] = False

    max_no_exceed = dp[target_seconds]
    # 检查是否存在任何不超过目标总和的组合（包括0，只要存在至少一个视频剩余 ≤ target）
    has_feasible = max_no_exceed > 0 or any(rem <= target_seconds for rem in rem_list)

    if has_feasible:
        # 回溯组合
        selected = []
        j = target_seconds
        for i in range(n - 1, -1, -1):
            if j >= rem_list[i] and choose[i][j]:
                selected.append(i)
                j -= rem_list[i]
        selected.sort(key=lambda i: unfinished[i]["remaining_sec"])  # 按剩余时长升序
        chosen_videos = [unfinished[i] for i in selected]
    else:
        # 所有视频剩余时长都大于目标，选剩余时长最小的一个
        unfinished.sort(key=lambda x: x["remaining_sec"])
        chosen_videos = [unfinished[0]]
        print(f"    所有视频剩余时长均超过需观看时长 {target_seconds} 秒，选择最少超出的视频")

    total = sum(v["remaining_sec"] for v in chosen_videos)
    print(f"    课程下选取 {len(chosen_videos)} 个视频，总剩余 {total} 秒（目标 {target_seconds} 秒）")
    return chosen_videos


