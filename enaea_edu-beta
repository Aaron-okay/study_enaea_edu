        # 3.2 video 课程处理（限差背包，目标为剩余时间 R）
        if R > 0 and videos:
            selected_videos = limited_knapsack(videos, R, limit=60)
            for course in selected_videos:
                # 获取课程下的子视频列表
                detail_url = (
                    f"https://study.enaea.edu.cn/course.do?action=getCourseContentList"
                    f"&courseId={course['course_id']}&circleId={circle_id}&_={timestamp}"
                )
                resp = rq.post(detail_url, headers=headers).json()
                raw_list = resp["result"]["list"]
                total_subs = resp["courseContentsTotalCount"]

                # 标准化子视频信息，过滤已完成的子视频
                sub_items = []
                for v in raw_list:
                    sub_len = time_str_to_seconds(v["length"])
                    prog = int(v["studyProgress"])
                    if prog == 100:
                        continue
                    sub_rem = sub_len - int(sub_len * prog / 100)
                    sub_items.append({
                        "video_id": v["id"],
                        "filename": v["filename"],
                        "length_sec": sub_len,
                        "studyProgress": v["studyProgress"],
                        "remaining_sec": sub_rem,
                    })
                print(f"  课程《{course['title']}》有 {total_subs} 个子视频，选择最优片段...")
                # 从子视频中选取满足该课程剩余时长的组合（同样使用限差背包）
                chosen_subs = limited_knapsack(sub_items, course['remaining_sec'], limit=60)

                # 构建 content_list
                content_list = []
                for sv in chosen_subs:
                    content_list.append({
                        "video_id": sv["video_id"],
                        "fileName": sv["filename"],
                        "studyProgress": sv["studyProgress"],
                        "length": sv["length_sec"],
                        "actual_watch_sec": sv["remaining_sec"]  # 需观看的剩余时长
                    })
                course_list.append({
                    "course_title": course["title"],
                    "course_type": "video",
                    "total_sec": course["total_sec"],
                    "remaining_to_watch_sec": course["remaining_sec"],
                    "already_watched_sec": course["watched_sec"],
                    "course_id": course["course_id"],
                    "video_id": None,  # video 课程无单视频ID
                    "content_list": content_list
                })

        # 4. 组装章节结果
        result_chapters.append({
            "chapter_name": chapter_name,
            "circleId": circle_id,
            "syllabusId": syllabus_id,
            "required_seconds": chapter['required_seconds'],
            "studied_seconds": chapter['studied_seconds'],
            "remaining_study_time": remaining_study_time,
            "course_list": course_list
        })

    return result_chapters


def limited_knapsack(items: List[Dict], target: int, limit: int = 60) -> List[Dict]:
    """
    限差 0-1 背包算法：在总时长 ≤ target+limit 的约束下求最大总时长。
    若最大值 ≥ target，返回对应组合；否则退化为不超过 target 的最优解。

    参数:
        items: 物品列表，每个物品需包含 'remaining_sec' 字段表示所需时长（秒）。
        target: 目标总时长（秒）。
        limit: 允许的最大超出量（秒），默认 60 秒。
    返回:
        选中的物品列表，按 remaining_sec 升序排列。
    """
    if not items:
        return []
    n = len(items)
    rem = [it['remaining_sec'] for it in items]
    capacity = target + limit
    dp = [0] * (capacity + 1)
    choose = [[False] * (capacity + 1) for _ in range(n)]

    # 动态规划求最大不超过 capacity 的总时长
    for i in range(n):
        for j in range(capacity, rem[i] - 1, -1):
            if dp[j - rem[i]] + rem[i] > dp[j]:
                dp[j] = dp[j - rem[i]] + rem[i]
                choose[i][j] = True

    best = dp[capacity]
    if best < target:
        # 退化：重新计算不超过 target 的最优解
        capacity = target
        dp = [0] * (target + 1)
        choose = [[False] * (target + 1) for _ in range(n)]
        for i in range(n):
            for j in range(target, rem[i] - 1, -1):
                if dp[j - rem[i]] + rem[i] > dp[j]:
                    dp[j] = dp[j - rem[i]] + rem[i]
                    choose[i][j] = True
        best = dp[target]

    # 回溯组合
    selected = []
    j = capacity
    for i in range(n - 1, -1, -1):
        if j >= rem[i] and choose[i][j]:
            selected.append(i)
            j -= rem[i]
    selected.sort(key=lambda i: items[i]['remaining_sec'])
    return [items[i] for i in selected]


def min_cover_knapsack(items: List[Dict], target: int) -> List[Dict]:
    """
    最小覆盖 0-1 背包：选出若干物品，使其总时长之和 ≥ target，且超出值最小。
    若所有物品总时长仍 < target，则返回全部物品。

    参数:
        items: 物品列表，每个物品需包含 'remaining_sec' 字段。
        target: 需要覆盖的最低总时长（秒）。
    返回:
        选中的物品列表，按 remaining_sec 升序排列。
    """
    if not items:
        return []
    total_sum = sum(it['remaining_sec'] for it in items)
    if total_sum < target:
        return sorted(items, key=lambda x: x['remaining_sec'])

    n = len(items)
    rem = [it['remaining_sec'] for it in items]
    max_cap = total_sum
    dp = [False] * (max_cap + 1)
    dp[0] = True
    prev = [[False] * (max_cap + 1) for _ in range(n)]

    # 可行性背包 DP
    for i in range(n):
        for j in range(max_cap, rem[i] - 1, -1):
            if not dp[j] and dp[j - rem[i]]:
                dp[j] = True
                prev[i][j] = True

    # 找到最小的 j >= target 且可达
    best_j = -1
    for j in range(target, max_cap + 1):
        if dp[j]:
            best_j = j
            break
    if best_j == -1:
        return sorted(items, key=lambda x: x['remaining_sec'])  # fallback

    # 回溯
    selected = []
    j = best_j
    for i in range(n - 1, -1, -1):
        if j >= rem[i] and prev[i][j]:
            selected.append(i)
            j -= rem[i]
    selected.sort(key=lambda i: items[i]['remaining_sec'])
    return [items[i] for i in selected]


def time_str_to_seconds(t: str) -> int:
    """
    将 HH:MM:SS 格式的时间字符串转换为秒数。

    参数:
        t: 时间字符串，如 "01:23:45"
    返回:
        int: 对应的总秒数，若转换失败返回 0。
    """
    try:
        h, m, s = map(int, t.split(':'))
        return h * 3600 + m * 60 + s
    except:
        return 0


